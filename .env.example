# AI Provider Configuration
# Copy this file to .env and add your API keys（将这个文件的内容复制到.env文件，并添加AI提供方的API keys）

# DeepSeek API Key
# Get your key at: https://platform.deepseek.com/api_keys
# 从DeepSeek开放平台[https://platform.deepseek.com/api_keys]获取API Key并替换 -> "sk-11111111111111111111111111111111"
DEEPSEEK_API_KEY=sk-11111111111111111111111111111111

# Node Environment
NODE_ENV=development